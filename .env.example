# Anthropic (Claude 3.5)
ANTHROPIC_API_KEY=
MODEL_NAME=claude-3-5-sonnet-latest

# Telegram — create bot via @BotFather
TELEGRAM_BOT_TOKEN=
# Operator Telegram chat id (user or group supergroup id, often negative for groups)
OPERATOR_CHAT_ID=
# Optional — alerts for escalation / aggressive sentiment (defaults to OPERATOR_CHAT_ID if empty)
MANAGER_CHAT_ID=

# PostgreSQL — Railway: додай сервіс Postgres, скопіюй DATABASE_URL у Variables основного сервісу
DATABASE_URL=postgresql://user:password@host:5432/railway
# Для публічного хоста Railway Postgres зазвичай потрібно: DATABASE_SSL=true
DATABASE_SSL=false

# Used to register Telegram webhook on startup when SET_WEBHOOK_ON_START=true
# Telegram webhook endpoint is fixed to: ${WEBHOOK_BASE_URL}/api/webhooks/telegram
WEBHOOK_BASE_URL=https://your-app.up.railway.app
# Optional Telegram secret_token for webhook verification
TELEGRAM_WEBHOOK_SECRET=

SET_WEBHOOK_ON_START=false
LOG_LEVEL=INFO

# Railway sets PORT automatically; local default below
HOST=0.0.0.0
PORT=8000
